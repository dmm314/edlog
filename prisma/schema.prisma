generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── ENUMS ────────────────────────────────────────────────

enum Role {
  TEACHER
  SCHOOL_ADMIN
  REGIONAL_ADMIN
}

enum CodeType {
  SCHOOL_REGISTRATION
}

enum SchoolStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum EngagementLevel {
  LOW
  MEDIUM
  HIGH
}

enum Gender {
  MALE
  FEMALE
}

enum NotificationType {
  LOG_REMINDER
  WEEKLY_SUMMARY
  COMPLIANCE_WARNING
  LOG_REVIEWED
  NEW_TEACHER
  CURRICULUM_GAP
  GENERAL
  SCHOOL_INVITATION
  SCHOOL_ANNOUNCEMENT
  REGIONAL_ANNOUNCEMENT
}

enum TeacherSchoolStatus {
  PENDING
  ACTIVE
  REMOVED
}

// ── USERS & AUTH ─────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  teacherCode  String?   @unique // Human-readable code, e.g., "TCH-A1B2C3"
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  role         Role      @default(TEACHER)
  isVerified   Boolean   @default(false)
  dateOfBirth  DateTime?
  gender       Gender?
  photoUrl     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // School relationship (primary school, for TEACHER and SCHOOL_ADMIN)
  school        School?        @relation("SchoolTeachers", fields: [schoolId], references: [id])
  schoolId      String?
  adminOfSchool School?        @relation("SchoolAdmin")

  // Multi-school memberships (for teachers teaching at multiple schools)
  teacherSchools TeacherSchool[]

  // Region relationship (for REGIONAL_ADMIN)
  regionAdmin  Region?  @relation("RegionalAdmins", fields: [regionId], references: [id])
  regionId     String?

  // Registration codes
  codesCreated RegistrationCode[] @relation("CodesCreated")
  codesUsed    RegistrationCode[] @relation("CodesUsed")

  // Teacher features
  entries      LogbookEntry[]
  assignments  TeacherAssignment[]
  sessions     Session[]
  notifications Notification[]
  hodSubjects  HeadOfDepartment[]
  assessments  Assessment[]
  entryRemarks EntryRemark[]

  @@index([schoolId, role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── GEOGRAPHY (Cameroon Regions & Divisions) ─────────────

model Region {
  id        String     @id @default(cuid())
  name      String     @unique
  code      String     @unique // e.g., "CE", "SW", "NW"
  capital   String
  divisions Division[]
  schools   School[]
  admins    User[]     @relation("RegionalAdmins")
  codes     RegistrationCode[]
  createdAt DateTime   @default(now())
}

model Division {
  id        String   @id @default(cuid())
  name      String
  regionId  String
  region    Region   @relation(fields: [regionId], references: [id])
  schools   School[]
  createdAt DateTime @default(now())

  @@unique([regionId, name])
}

// ── REGISTRATION CODES ───────────────────────────────────

model RegistrationCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        CodeType  @default(SCHOOL_REGISTRATION)
  regionId    String
  region      Region    @relation(fields: [regionId], references: [id])
  createdById String
  createdBy   User      @relation("CodesCreated", fields: [createdById], references: [id])
  usedAt      DateTime?
  usedById    String?
  usedBy      User?     @relation("CodesUsed", fields: [usedById], references: [id])
  schoolId    String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([regionId])
  @@index([code])
}

// ── SCHOOL ───────────────────────────────────────────────

model School {
  id             String       @id @default(cuid())
  name           String
  code           String       @unique
  schoolType     String?      // Government, Private Lay, Private Confessional - Catholic/Protestant/Islamic, Community
  principalName  String?
  principalPhone String?
  foundingDate   DateTime?
  status         SchoolStatus @default(ACTIVE)
  profileComplete Boolean     @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Geography
  regionId   String
  region     Region   @relation(fields: [regionId], references: [id])
  divisionId String
  division   Division @relation(fields: [divisionId], references: [id])

  // Admin
  adminId  String? @unique
  admin    User?   @relation("SchoolAdmin", fields: [adminId], references: [id])

  // Relations
  teachers       User[]              @relation("SchoolTeachers")
  teacherSchools TeacherSchool[]
  classes        Class[]
  subjects       SchoolSubject[]
  divisions      SubjectDivision[]
  assignments    TeacherAssignment[]
  timetableSlots TimetableSlot[]
  periodSchedule PeriodSchedule[]
  hods           HeadOfDepartment[]
  assessments    Assessment[]
}

// ── PERIOD SCHEDULE (school-wide bell times) ─────────────

model PeriodSchedule {
  id         String @id @default(cuid())
  schoolId   String
  school     School @relation(fields: [schoolId], references: [id])
  periodNum  Int    // 1, 2, 3, ..., 8
  label      String // "Period 1", "Period 2", etc.
  startTime  String // "07:30"
  endTime    String // "08:30"
  createdAt  DateTime @default(now())

  @@unique([schoolId, periodNum])
}

// ── TEACHER-SCHOOL MEMBERSHIPS (multi-school support) ────

model TeacherSchool {
  id        String              @id @default(cuid())
  teacherId String
  teacher   User                @relation(fields: [teacherId], references: [id])
  schoolId  String
  school    School              @relation(fields: [schoolId], references: [id])
  status    TeacherSchoolStatus @default(PENDING)
  isPrimary Boolean             @default(false)
  joinedAt  DateTime?
  createdAt DateTime            @default(now())

  @@unique([teacherId, schoolId])
  @@index([teacherId])
  @@index([schoolId])
}

// ── CLASSES ──────────────────────────────────────────────

model Class {
  id           String   @id @default(cuid())
  name         String   // "Form 1A", "Lower Sixth Science A"
  abbreviation String?  // "F1A", "LSSA"
  level        String   // "Form 1", "Form 2", ..., "Lower Sixth", "Upper Sixth"
  stream       String?  // "Science", "Arts", "General"
  section      String?  // "A", "B", "C", etc.
  year         Int
  createdAt    DateTime @default(now())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])

  entries     LogbookEntry[]
  assignments TeacherAssignment[]
  subjects    ClassSubject[]
  assessments Assessment[]

  @@unique([schoolId, name, year])
}

// ── CURRICULUM ───────────────────────────────────────────

model Subject {
  id        String          @id @default(cuid())
  name      String          @unique
  code      String          @unique
  category  String?
  createdAt DateTime        @default(now())
  topics    Topic[]
  schools   SchoolSubject[]
  classes   ClassSubject[]
  assignments TeacherAssignment[]
  divisions   SubjectDivision[]
  hods        HeadOfDepartment[]
  assessments Assessment[]
}

model Topic {
  id         String   @id @default(cuid())
  name       String
  classLevel String   // "Form 1", "Form 2", ..., "Lower Sixth", "Upper Sixth"
  moduleNum  Int?
  moduleName String?
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])

  entries LogbookEntry[] @relation("EntryTopics")
  assessments Assessment[] @relation("AssessmentTopics")

  @@unique([subjectId, classLevel, name])
  @@index([subjectId, classLevel])
}

model SchoolSubject {
  id        String  @id @default(cuid())
  schoolId  String
  school    School  @relation(fields: [schoolId], references: [id])
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([schoolId, subjectId])
}

model ClassSubject {
  id        String  @id @default(cuid())
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([classId, subjectId])
}

// ── SUBJECT DIVISIONS (school-specific sub-subjects) ─────

model SubjectDivision {
  id        String   @id @default(cuid())
  name      String   // "Physical Chemistry", "Directed Writing"
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  levels    String[] // Class levels this division applies to, e.g. ["Form 4", "Form 5"] or ["Lower Sixth", "Upper Sixth"]. Empty = all levels.
  createdAt DateTime @default(now())

  assignments TeacherAssignment[]

  @@unique([schoolId, subjectId, name])
  @@index([schoolId, subjectId])
}

// ── HEAD OF DEPARTMENT (HOD) ─────────────────────────────

model HeadOfDepartment {
  id        String   @id @default(cuid())
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id])
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())

  @@unique([schoolId, subjectId])
  @@index([teacherId])
  @@index([schoolId])
}

// ── TEACHER ASSIGNMENTS & TIMETABLE ──────────────────────

model TeacherAssignment {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    User     @relation(fields: [teacherId], references: [id])
  classId    String
  class      Class    @relation(fields: [classId], references: [id])
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  divisionId String?
  division   SubjectDivision? @relation(fields: [divisionId], references: [id])
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  periods TimetableSlot[]
  entries LogbookEntry[]

  @@unique([teacherId, classId, subjectId, divisionId])
  @@index([teacherId])
  @@index([schoolId])
  @@index([teacherId, schoolId])
}

model TimetableSlot {
  id           String            @id @default(cuid())
  assignmentId String
  assignment   TeacherAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  dayOfWeek    Int               // 1=Monday ... 5=Friday
  startTime    String            // "07:30"
  endTime      String            // "08:30"
  periodLabel  String            // "Period 1"
  schoolId     String
  school       School            @relation(fields: [schoolId], references: [id])
  createdAt    DateTime          @default(now())

  entries LogbookEntry[]

  @@index([schoolId, dayOfWeek])
  @@index([assignmentId])
}

// ── LOGBOOK ENTRIES (CORE) ───────────────────────────────

model LogbookEntry {
  id                String           @id @default(cuid())
  date              DateTime
  period            Int?
  duration          Int              @default(60)
  moduleName        String?          // Selected module name
  topicText         String?          // Free-text topic typed by teacher
  notes             String?          @db.Text
  objectives        Json?            // Array of { text: string, proportion: string } or legacy plain string
  signatureData     String?          @db.Text
  status            String           @default("SUBMITTED")
  studentAttendance Int?
  engagementLevel   EngagementLevel?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  teacherId       String
  teacher         User              @relation(fields: [teacherId], references: [id])
  classId         String
  class           Class             @relation(fields: [classId], references: [id])
  assignmentId    String?
  assignment      TeacherAssignment? @relation(fields: [assignmentId], references: [id])
  timetableSlotId String?
  timetableSlot   TimetableSlot?    @relation(fields: [timetableSlotId], references: [id])

  // CBA Fields (Cameroon Competency-Based Approach)
  familyOfSituation   String?          // Auto-populated from curriculum, teacher can override

  bilingualActivity   Boolean          @default(false)  // Was a bilingual activity conducted?
  bilingualType       String?          // "game", "discussion", "quiz", "role_play", "exercise", "translation", "song"
  bilingualNote       String?          // Brief description if needed

  integrationActivity String?          // "Learners are able to..." completion text
  integrationLevel    String?          // "basic", "intermediate", "advanced"
  integrationStatus   String?          // "completed", "partial", "carried_over"

  lessonMode          String?          // "physical", "digital", "hybrid"
  digitalTools        String[]         // If digital/hybrid: ["projector", "youtube", "zoom", "whatsapp", "powerpoint", etc.]

  // Assignment tracking
  assignmentGiven     Boolean          @default(false)  // Was homework/assignment given?
  assignmentDetails   String?          // Brief details about the assignment
  assignmentReviewed  Boolean?         // Was a previous assignment reviewed this class?

  // Many-to-many topics (kept for backward compat)
  topics Topic[] @relation("EntryTopics")

  remarks  EntryRemark[]

  @@index([teacherId, date])
  @@index([classId, date])
}

// ── ASSESSMENTS ─────────────────────────────────────────

model Assessment {
  id            String   @id @default(cuid())
  teacherId     String
  teacher       User     @relation(fields: [teacherId], references: [id])
  classId       String
  class         Class    @relation(fields: [classId], references: [id])
  subjectId     String
  subject       Subject  @relation(fields: [subjectId], references: [id])
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id])

  assignmentId  String?

  title         String            // "First Sequence Test", "Mock Exam", "Class Test 3"
  type          String            // "sequence_test", "class_test", "assignment", "mock_exam", "exam"
  date          DateTime          // Date the test was administered
  totalMarks    Int               // Maximum possible marks (e.g., 20, 50, 100)
  passMark      Int               // Minimum marks to pass (e.g., 10 out of 20)

  // Topics tested (links to curriculum)
  topicsTested  Topic[]           @relation("AssessmentTopics")
  topicsNote    String?           // Free-text description of what was tested

  // Results (entered later, after correction)
  corrected         Boolean   @default(false)
  correctionDate    DateTime?
  totalStudents     Int?           // Total who sat the test
  totalMale         Int?           // Male students who sat
  totalFemale       Int?           // Female students who sat
  totalPassed       Int?           // Students who scored >= passMark
  malePassed        Int?
  femalePassed      Int?
  highestMark       Float?
  lowestMark        Float?
  averageMark       Float?

  // Auto-calculated rates
  passRate          Float?              // Auto-calculated: totalPassed/totalStudents * 100
  malePassRate      Float?              // Auto-calculated: malePassed/totalMale * 100
  femalePassRate    Float?              // Auto-calculated: femalePassed/totalFemale * 100

  // Notification tracking
  notifiedParents   Boolean   @default(false)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([teacherId, classId])
  @@index([schoolId, date])
  @@index([classId, subjectId])
}

// ── NOTIFICATIONS ────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  link      String?

  // Track who sent this notification
  senderRole  String?        // "SCHOOL_ADMIN" or "REGIONAL_ADMIN" — null for system notifications
  schoolId    String?        // School that sent it (for school broadcasts)

  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

// ── ENTRY REMARKS (feedback & review system) ────────────

model EntryRemark {
  id          String   @id @default(cuid())
  entryId     String
  entry       LogbookEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  authorRole  String   // "TEACHER", "HOD", "SCHOOL_ADMIN", "REGIONAL_ADMIN"
  content     String   @db.Text
  remarkType  String   // "self_reflection", "hod_review", "admin_verification", "inspector_note"
  createdAt   DateTime @default(now())

  @@index([entryId, createdAt])
  @@index([authorId])
}
